<?xml version="1.0" encoding="utf-8"?>
<!--
  CRM VB.NET - Web.config
  Configuración principal de la aplicación
-->
<configuration>

  <!-- Cadena de conexión a MySQL -->
  <connectionStrings>
    <add name="CRMConnection"
         connectionString="Server=localhost;Port=3306;Database=CRM_VBNet;Uid=root;Pwd=;SslMode=none;CharSet=utf8mb4;"
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>

  <appSettings>
    <!-- Configuración general -->
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />

    <!-- Configuración de uploads -->
    <add key="MaxPhotoSizeMB" value="5" />
    <add key="MaxLogoSizeMB" value="2" />
    <add key="AllowedImageExtensions" value=".jpg,.jpeg,.png,.gif,.webp" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.8">
      <assemblies>
        <add assembly="System.Web.Mvc, Version=5.2.9.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      </assemblies>
    </compilation>

    <httpRuntime targetFramework="4.8" maxRequestLength="10240" />

    <!-- Sesión: timeout de 30 minutos -->
    <sessionState mode="InProc" timeout="30" />

    <!-- Páginas de error personalizadas -->
    <customErrors mode="RemoteOnly" defaultRedirect="~/Account/Login">
      <error statusCode="404" redirect="~/Account/Login" />
    </customErrors>
  </system.web>

  <system.webServer>
    <!-- Permitir uploads grandes (10MB) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>

    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>

</configuration>
